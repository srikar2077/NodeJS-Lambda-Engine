{
  "name": "@srikar2077/nodejs-lambda-engine-infrastructure",
  "version": "1.3.0",
  "description": "AWS CDK infrastructure for nodejs-lambda-engine",
  "private": true,
  "type": "commonjs",
  "main": "app.js",
  "scripts": {
    "build": "tsc",
    "clean": "rimraf cdk.out coverage dist",
    "cdk": "cdk",
    "synth": "cdk synth",
    "deploy": "cdk deploy",
    "deploy:all": "cdk deploy --all",
    "diff": "cdk diff",
    "destroy": "cdk destroy",
    "destroy:all": "cdk destroy --all",
    "local:start": "docker-compose -f ../docker-compose.yml up -d",
    "local:stop": "docker-compose -f ../docker-compose.yml down",
    "local:logs": "docker-compose -f ../docker-compose.yml logs -f localstack",
    "local:bootstrap": "cdklocal bootstrap",
    "local:synth": "cdklocal synth",
    "local:deploy": "cdklocal deploy --all --require-approval never",
    "local:destroy": "cdklocal destroy --all --force",
    "local:diff": "cdklocal diff",
    "test": "jest --coverage=false --silent --verbose",
    "test:coverage": "jest --coverage --silent --verbose",
    "test:watch": "jest --watch"
  },
  "devDependencies": {
    "@types/jest": "30.0.0",
    "@types/node": "25.6.0",
    "aws-cdk": "2.1118.0",
    "aws-cdk-local": "3.0.4",
    "esbuild": "0.28.0",
    "jest": "30.3.0",
    "rimraf": "6.1.3",
    "ts-jest": "29.4.9",
    "ts-node": "10.9.2",
    "typescript": "5.9.3"
  },
  "dependencies": {
    "aws-cdk-lib": "2.248.0",
    "constructs": "10.6.0",
    "dotenv": "17.4.1",
    "source-map-support": "0.5.21",
    "zod": "4.3.6"
  }
}
